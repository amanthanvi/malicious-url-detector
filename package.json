{
  "name": "scrutinix",
  "version": "3.0.0",
  "description": "FOSS multi-signal URL threat analyzer with streamed NDJSON results, batch scans, and local history.",
  "private": true,
  "license": "MIT",
  "homepage": "https://www.scrutinix.net",
  "repository": {
    "type": "git",
    "url": "https://github.com/amanthanvi/scrutinix.git"
  },
  "bugs": {
    "url": "https://github.com/amanthanvi/scrutinix/issues"
  },
  "keywords": [
    "security",
    "cybersecurity",
    "url-scanner",
    "phishing-detection",
    "threat-intelligence",
    "nextjs",
    "typescript"
  ],
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "format": "prettier",
    "test:unit": "vitest --config vitest.unit.config.ts",
    "test:integration": "vitest --config vitest.integration.config.ts",
    "test:e2e": "npm run build && node ./scripts/run-e2e.mjs",
    "lighthouse": "node ./scripts/run-lighthouse.mjs"
  },
  "dependencies": {
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.36.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "geist": "^1.7.0",
    "hack-font": "^3.3.0",
    "idb": "^8.0.3",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "chrome-launcher": "^1.2.1",
    "eslint": "^9.38.0",
    "eslint-config-next": "16.1.6",
    "lighthouse": "^13.0.3",
    "msw": "^2.12.10",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
